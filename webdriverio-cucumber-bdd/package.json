{
  "name": "webdriverio-cucumber-bdd",
  "version": "1.0.0",
  "description": "WebdriverIO + Cucumber BDD Framework",
  "private": true,
  "scripts": {
    "test": "node scripts/validate-framework.js",
    "test:e2e": "echo Generate client tests first, then enable the native runner.",
    "test:smoke": "npm run test:e2e -- --grep @smoke",
    "test:sanity": "npm run test:e2e -- --grep @sanity",
    "test:regression": "npm run test:e2e -- --grep @regression",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:serve": "allure serve allure-results",
    "test:parallel": "npx wdio run wdio.conf.js --maxInstances=4",
    "test:sequential": "npx wdio run wdio.conf.js --maxInstances=1"
  },
  "dependencies": {},
  "devDependencies": {
    "dotenv": "^16.4.5",
    "@wdio/cli": "^8.38.0",
    "@wdio/local-runner": "^8.38.0",
    "@wdio/mocha-framework": "^8.38.0",
    "webdriverio": "^8.38.0",
    "@cucumber/cucumber": "^10.9.0",
    "@wdio/allure-reporter": "^9.0.0"
  },
  "type": "module"
}
