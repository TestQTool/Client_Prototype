<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Parallel Suite" parallel="methods" thread-count="4">
  <listeners>
    <listener class-name="listeners.AllureTestNgListener"/>
  </listeners>
  <test name="Parallel Suite Tests">
    
    <packages>
      <package name="tests.*"/>
    </packages>
  </test>
</suite>
