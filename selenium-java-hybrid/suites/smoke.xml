<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Smoke Suite" parallel="false" thread-count="1">
  <listeners>
    <listener class-name="listeners.AllureTestNgListener"/>
  </listeners>
  <test name="Smoke Suite Tests">
    <groups>
      <run>
        <include name="smoke"/>
      </run>
    </groups>
    <packages>
      <package name="tests.*"/>
    </packages>
  </test>
</suite>
