<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Parallel Suite" parallel="methods" thread-count="4">
  <test name="Parallel Tagged Tests">
    <groups>
      <run>
        <include name="smoke"/>
        <include name="sanity"/>
        <include name="regression"/>
      </run>
    </groups>
    <packages>
      <package name="tests.*"/>
      <package name="runner.*"/>
      <package name="stepDefinitions.*"/>
    </packages>
  </test>
</suite>
