<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Qentrix Login Test Suite" parallel="methods" thread-count="2">
    
    <listeners>
        <listener class-name="org.testng.reporters.EmailableReporter2"/>
    </listeners>
    
    <test name="User Login Functionality Tests">
        <classes>
            <class name="com.qentrix.tests.LoginTest">
                <methods>
                    <include name="testValidLogin"/>
                    <include name="testInvalidUsername"/>
                    <include name="testInvalidPassword"/>
                    <include name="testEmptyUsername"/>
                    <include name="testEmptyPassword"/>
                    <include name="testEmptyCredentials"/>
                    <include name="testLoginWithDataProvider"/>
                </methods>
            </class>
        </classes>
    </test>
    
</suite>