<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Qentrix Test Suite" parallel="false" thread-count="1">
    <parameter name="browser" value="chrome"/>
    
    <test name="Leave Module Tests">
        <classes>
            <class name="com.qentrix.tests.LeaveTests">
                <methods>
                    <include name="testApplySickLeaveWithHalfDayOption"/>
                    <include name="testCannotApplyLeaveWithInvalidDateRange"/>
                    <include name="testViewLeaveCalendar"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>