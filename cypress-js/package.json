{
  "name": "cypress-js",
  "version": "1.0.0",
  "description": "Cypress + JavaScript Framework",
  "private": true,
  "scripts": {
    "test": "node scripts/validate-framework.js",
    "test:e2e": "echo Generate client tests first, then enable the native runner.",
    "test:smoke": "npm run test:e2e -- --grep @smoke",
    "test:sanity": "npm run test:e2e -- --grep @sanity",
    "test:regression": "npm run test:e2e -- --grep @regression",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:serve": "allure serve allure-results",
    "test:parallel": "npx cypress run --config video=false",
    "test:sequential": "npx cypress run --config numTestsKeptInMemory=1"
  },
  "dependencies": {},
  "devDependencies": {
    "dotenv": "^16.4.5",
    "cypress": "^13.13.0",
    "allure-cypress": "^3.0.6"
  },
  "type": "module"
}
