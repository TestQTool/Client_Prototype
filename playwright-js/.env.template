# QualityMatrix Playwright JS — Environment Variables
# Copy this file to .env and fill in the values.
# The NextGenAI platform injects these from ClientConfiguration automatically.

# ── Application ───────────────────────────────────────────────────────────────
BASE_URL=https://your-app.com
ENVIRONMENT=qa

# ── Credentials (override credentials.csv for CI) ────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── CI behaviour ─────────────────────────────────────────────────────────────
CI=false
HEADLESS=true
