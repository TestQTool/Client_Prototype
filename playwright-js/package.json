{
  "name" : "playwright-js",
  "version" : "2.0.0",
  "description" : "StaticFrameworks — Playwright JS. Generic framework for any client, any domain.",
  "scripts" : {
    "install:browsers" : "npx playwright install --with-deps chromium firefox webkit",
    "test" : "npx playwright test",
    "test:chrome" : "npx playwright test --project=Chrome",
    "test:firefox" : "npx playwright test --project=Firefox",
    "test:edge" : "npx playwright test --project=Edge",
    "test:safari" : "npx playwright test --project=Safari",
    "test:smoke" : "npx playwright test --grep @smoke",
    "test:regression" : "npx playwright test --grep @regression",
    "test:smoke:chrome" : "npx playwright test --grep @smoke --project=Chrome",
    "test:smoke:firefox" : "npx playwright test --grep @smoke --project=Firefox",
    "test:regression:chrome" : "npx playwright test --grep @regression --project=Chrome",
    "test:regression:firefox" : "npx playwright test --grep @regression --project=Firefox",
    "test:Saucedemo-Smoke-Chrome" : "npx playwright test tests/Saucedemo.test.js --grep @smoke --project=Chrome",
    "test:Saucedemo-Regression-Chrome" : "npx playwright test tests/Saucedemo.test.js --grep @regression --project=Chrome",
    "test:Saucedemo-Smoke-Firefox" : "npx playwright test tests/Saucedemo.test.js --grep @smoke --project=Firefox",
    "test:Saucedemo-Regression-Firefox" : "npx playwright test tests/Saucedemo.test.js --grep @regression --project=Firefox",
    "allure:generate" : "allure generate ./allure-results --clean -o allure-report",
    "allure:serve" : "allure serve ./allure-results",
    "report" : "npx playwright show-report",
    "test:e2e" : "npx playwright test"
  },
  "keywords" : [ "playwright", "test-automation", "automation" ],
  "author" : "Automation Team",
  "license" : "ISC",
  "devDependencies" : {
    "@playwright/test" : "^1.49.1",
    "@types/node" : "^22.10.2",
    "allure-playwright" : "^2.4.0"
  },
  "dependencies" : {
    "csv-parse" : "^5.6.0",
    "dotenv" : "^16.6.1",
    "nodemailer" : "^6.9.16"
  },
  "type" : "module"
}