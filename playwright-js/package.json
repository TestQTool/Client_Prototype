{
  "name" : "playwright-automation",
  "version" : "1.0.0",
  "description" : "Playwright automation framework",
  "scripts" : {
    "test" : "npx playwright test",
    "test:ForgotPassword-Smoke-Chrome" : "npx playwright test tests/ForgotPassword.test.js --grep @smoke --project=Chrome",
    "test:ForgotPassword-Regression-Chrome" : "npx playwright test tests/ForgotPassword.test.js --grep @regression --project=Chrome",
    "test:ForgotPassword-Smoke-Firefox" : "npx playwright test tests/ForgotPassword.test.js --grep @smoke --project=Firefox",
    "test:ForgotPassword-Regression-Firefox" : "npx playwright test tests/ForgotPassword.test.js --grep @regression --project=Firefox"
  },
  "devDependencies" : {
    "@playwright/test" : "^1.40.0"
  },
  "dependencies" : {
    "csv-parse" : "^5.5.6"
  }
}